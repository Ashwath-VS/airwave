# AirWave — Airline Fare Intelligence Engine
# Copy to .env and fill in your keys

# LLM: Gemini 2.5 Flash via OpenAI-compatible endpoint
# Get key: https://aistudio.google.com/app/apikey
LLM_API_KEY=your_gemini_api_key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-2.5-flash

# Optional boost model (cheaper/faster for agent turns)
LLM_BOOST_API_KEY=your_gemini_api_key
LLM_BOOST_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_BOOST_MODEL_NAME=gemini-2.0-flash

# ZEP Cloud — agent long-term memory
# Free tier sufficient: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key

# Data APIs
# SerpApi (Google Flights): https://serpapi.com/
SERPAPI_KEY=your_serpapi_key
# Travelpayouts (fare history): https://travelpayouts.com/
TRAVELPAYOUTS_KEY=your_travelpayouts_key
