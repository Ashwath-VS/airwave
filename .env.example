# AirWave -- Airline Fare Intelligence Engine
# Copy to .env and fill in your keys
# cp .env.example .env

# -- LLM (Required) -----------------------------------------------------------
# AirWave agents run on Gemini 2.5 Flash by default.
# Get a free key at: https://aistudio.google.com/app/apikey
LLM_API_KEY=your_gemini_api_key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-2.5-flash

# Optional: faster/cheaper model for agent reasoning turns
# If not set, falls back to LLM_API_KEY / LLM_BASE_URL above
LLM_BOOST_API_KEY=your_gemini_api_key
LLM_BOOST_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_BOOST_MODEL_NAME=gemini-2.0-flash

# -- Fare Data (Optional -- fallback to synthetic if not set) -----------------
# Duffel NDC: Live airline fare offers via NDC connections
# Get access at: https://app.duffel.com/
# Use duffel_live_... for production. duffel_test_... returns test fares only.
DUFFEL_API_KEY=your_duffel_api_key

# SerpApi: Google Flights fare search
# Free tier available at: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key

# Travelpayouts / Aviasales: Historical fare baseline data
# Free API at: https://travelpayouts.com/developers/api
TRAVELPAYOUTS_KEY=your_travelpayouts_key

# -- ZEP Cloud (Optional -- not required for AirWave fare engine) -------------
# Only needed for the OASIS social simulation module (not AirWave).
# Free tier at: https://app.getzep.com/
ZEP_API_KEY=FILL_IN
